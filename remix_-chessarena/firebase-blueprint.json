{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with ELO rating, statistics, and wallet balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "country": { "type": "string" },
        "elo": { "type": "integer" },
        "matchesPlayed": { "type": "integer" },
        "wins": { "type": "integer" },
        "losses": { "type": "integer" },
        "walletBalance": { "type": "number" },
        "pendingBalance": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "status": { "type": "string", "enum": ["online", "offline", "in-game"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email"]
    },
    "Match": {
      "title": "Chess Match",
      "description": "Match tracking two players, entry fee, board state, timer, and outcomes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "whitePlayerId": { "type": "string" },
        "blackPlayerId": { "type": "string" },
        "entryFee": { "type": "number" },
        "prizePool": { "type": "number" },
        "boardFen": { "type": "string" },
        "pgn": { "type": "string" },
        "moves": { "type": "array" },
        "whiteTimer": { "type": "integer" },
        "blackTimer": { "type": "integer" },
        "currentTurn": { "type": "string", "enum": ["w", "b"] },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished", "draw", "resigned", "aborted"] },
        "winnerId": { "type": "string" },
        "drawOfferFrom": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entryFee", "status"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Deposit, withdrawal, entry fee, platform fee, or prize payout transactions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "entry_fee", "prize_win", "platform_fee"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "amount", "status"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "Real-time user notification for matchmaking, wallet, and game state",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["match_found", "opponent_joined", "deposit_completed", "withdrawal_completed", "prize_received"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "read"]
    },
    "ChatMessage": {
      "title": "Global Chat Message",
      "description": "A message sent in the global community lobby chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "text": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile records"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Chess match records"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Wallet and platform transactions"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications for users"
    },
    "/global_chat/{chatId}": {
      "schema": "ChatMessage",
      "description": "Global chat messages"
    }
  }
}
